# Freelance Job Search MCP Server - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# TELEGRAM NOTIFICATIONS (Recommended)
# ============================================================================
# Create a bot via @BotFather on Telegram
# Get chat ID by messaging your bot and visiting:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================================================
# DISCORD NOTIFICATIONS (Optional)
# ============================================================================
# Create a webhook in your Discord server settings

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# ============================================================================
# EMAIL NOTIFICATIONS (Optional)
# ============================================================================
# For Gmail, you'll need an App Password:
# https://support.google.com/accounts/answer/185833

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient@example.com

# ============================================================================
# PLATFORM API KEYS (Optional - for enhanced access)
# ============================================================================

# Freelancer.com OAuth (for posting jobs, not needed for search)
# FREELANCER_CLIENT_ID=
# FREELANCER_CLIENT_SECRET=

# LinkedIn Marketing API (requires approval)
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_ACCESS_TOKEN=

# Proxycurl (alternative for LinkedIn data)
# PROXYCURL_API_KEY=

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# HTTP server port (when running in HTTP mode)
HTTP_PORT=8000
